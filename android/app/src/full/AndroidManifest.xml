<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- FULL (sideload) flavor only. These let the user store downloads in a
         folder they choose in shared storage (Permanent / SD-card modes) so the
         files survive an app uninstall. "All files access" is requested at
         runtime via permission_handler (Permission.manageExternalStorage) only
         when one of those modes is selected.

         Deliberately NOT in src/main: Google Play rejects MANAGE_EXTERNAL_STORAGE
         for a music player, so the `play` flavor (which has no flavor manifest)
         ships without these and uses app-scoped storage instead. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"/>

    <!-- Camera for the iroh Remote Access QR pairing scanner (add-server → iroh
         tab). Kept in BOTH flavors (mobile_scanner also merges it into play), so
         Play users can scan a pairing QR; the camera only decodes the QR on-device,
         nothing captured/stored/sent. Play permission declaration + data-safety
         wording: see PLAY_COMPLIANCE.md. (uses-feature camera required=false is in
         the main manifest, keeping the app installable on camera-less devices.) -->
    <uses-permission android:name="android.permission.CAMERA"/>

    <!-- Distinct label so the "Plus" sideload build (mstream.music.plus) is
         tellable apart on-device from the Play build (mstream.music), which
         keeps the plain "mStream Music" label from the main manifest. -->
    <application android:label="mStream Plus" tools:replace="android:label"/>
</manifest>
